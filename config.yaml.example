# Texas LIHTC 2026 Agent - Example Configuration
# Copy to config.yaml and customize

pipeline:
  name: "Texas LIHTC 2026 Extraction"
  version: "v5.8"

discovery:
  seed_urls:
    - "https://www.tdhca.texas.gov/competitive-9-housing-tax-credits"
  max_pages: 550
  include_pdf_regex: "2026"

download:
  parallel_workers: 10
  max_new_downloads: 200

extraction:
  model: "gpt-4o-mini"
  parallel_workers: 4
  max_pages_per_pdf: 50

auto_recovery:
  census_tract: true
  poverty_rate: true
  tiebreaker_fields: true

output:
  formats:
    - csv
    - xlsx
    - jsonl
  include_review_queue: true

api:
  provider: "openai"  # or "anthropic", "ollama"
  openai:
    api_key_env: "OPENAI_API_KEY"
    model: "gpt-4o-mini"
  anthropic:
    api_key_env: "ANTHROPIC_API_KEY"
    model: "claude-sonnet-4-20250514"
  ollama:
    host: "http://localhost:11434"
    model: "qwen2.5:7b"
